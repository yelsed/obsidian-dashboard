+  // Public integration point for other plugins: open a Claude Code terminal
+  // rooted at an arbitrary working directory, optionally resuming a specific
+  // session and optionally seeding an initial prompt once the terminal is
+  // ready. The spawn override is captured by the view factory at construction,
+  // so clearing the pending field after `createNewTerminal` resolves is safe.
+  async openClaudeSessionInFolder(
+    workingDirectoryAbsolutePath: string,
+    resumeSessionId?: string,
+    initialPromptText?: string
+  ): Promise<ClaudeTerminalView | null> {
+    const extraArgs = resumeSessionId ? ["--resume", resumeSessionId] : [];
+    this.pendingTerminalSpawnOverride = {
+      cwd: workingDirectoryAbsolutePath,
+      extraArgs,
+    };
+
+    let terminalView: ClaudeTerminalView | null;
+    try {
+      terminalView = await this.createNewTerminal();
+    } finally {
+      this.pendingTerminalSpawnOverride = null;
+    }
+
+    if (terminalView && initialPromptText && initialPromptText.length > 0) {
+      try {
+        await terminalView.ensureReady();
+        terminalView.sendText(initialPromptText);
+      } catch {
+        // Terminal failed to become ready; the spawned claude process has
+        // already surfaced its own error notice, so swallow here.
+      }
+    }
+
+    return terminalView;
+  }
